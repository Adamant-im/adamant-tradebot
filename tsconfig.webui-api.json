{
  "compilerOptions": {
    "target": "ES2023",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "ignoreDeprecations": "6.0",
    "noImplicitAny": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "skipLibCheck": true,
    "strictNullChecks": false,
    "lib": ["ES2023"],
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "types/*": ["./types/*"]
    }
  },
  "include": [
    "api/lib/**/*.js",
    "api/services/account.js",
    "api/services/bot.js",
    "api/services/market.js",
    "api/routes/bot.js",
    "api/routes/market.js",
    "api/routes/account.js",
    "api/schemas/**/*.js",
    "types/webui-api/**/*.d.js",
    "types/webui-api/**/*.d.ts",
    "types/candles.d.js",
    "types/depth.d.js",
    "types/rates.d.js",
    "types/trades.d.js",
    "types/assets.d.js",
    "types/orders.d.js",
    "types/bot/general.d.js"
  ],
  "exclude": [
    "tests/api-webui/**"
  ]
}
